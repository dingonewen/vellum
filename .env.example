# Nylas application credentials (from Nylas Dashboard > Your App)
# Note: NYLAS_API_KEY doubles as the client secret for the OAuth code exchange in Nylas v3
NYLAS_API_KEY=
NYLAS_CLIENT_ID=
NYLAS_WEBHOOK_SECRET=   # fill in after creating the webhook in Nylas Dashboard (M5)

# Nylas API base URL — leave as default unless using EU region
NYLAS_API_URI=https://api.us.nylas.com

# PDF attachment generation via Gotenberg
GOTENBERG_URL=http://localhost:3001
ENABLE_PDF_ATTACHMENTS=true

# Public base URL of this server (used to build redirect/callback links)
# Set to your VM's public IP or domain, including port if non-standard
APP_BASE_URL=http://YOUR_VM_IP:3000
CALLBACK_URL=http://YOUR_VM_IP:3000/auth/callback

# Server
PORT=3000

# Anthropic API key and model (claude-haiku-4-5-20251001 is the default)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# SQLite database file path (relative to project root)
DATABASE_PATH=./data/vellum.db
